{
  "name": "easyoref",
  "version": "1.14.2",
  "description": "Real-time Israeli civil defense alerts → Telegram, filtered by your location",
  "type": "module",
  "bin": {
    "easyoref": "dist/bin.js"
  },
  "main": "dist/bot.js",
  "scripts": {
    "dev": "tsx watch src/bot.ts",
    "build": "tsc",
    "start": "node dist/bot.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "telegram",
    "oref",
    "red-alert",
    "israel",
    "pikud-haoref",
    "civil-defense",
    "rocket-alerts"
  ],
  "author": "Mikhail Kogan <kogan.mikhail@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikhailkogan17/easyoref.git",
    "directory": "packages/bot"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.1",
    "@langchain/openai": "^1.2.12",
    "@logtail/node": "^0.5.6",
    "bullmq": "^5.0.0",
    "chalk": "^5.3.0",
    "grammy": "^1.35.0",
    "input": "^1.0.1",
    "ioredis": "^5.3.0",
    "js-yaml": "^4.1.1",
    "qrcode-terminal": "^0.12.0",
    "telegram": "^2.26.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/**",
    "!dist/__tests__/**",
    "README.md",
    "LICENSE"
  ]
}

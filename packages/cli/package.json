    "chalk": "^5.3.0",
    "grammy": "^1.35.0",
    "@easyoref/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"

{
  "name": "easyoref-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "EasyOref — Real-time Israeli civil defense alerts → Telegram",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/bot",
    "build": "npm run build --workspaces",
    "start": "npm run start --workspace=packages/bot",
    "lint": "npm run lint --workspace=packages/bot",
    "typecheck": "npm run typecheck --workspace=packages/bot",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "author": "Mikhail Kogan <kogan.mikhail@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}

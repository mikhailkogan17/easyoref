{
  "name": "easyoref",
  "version": "1.0.0",
  "description": "Real-time Israeli civil defense alerts → Telegram, filtered by your location",
  "type": "module",
  "main": "dist/bot.js",
  "scripts": {
    "dev": "tsx watch src/bot.ts",
    "build": "tsc",
    "start": "node dist/bot.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "telegram",
    "oref",
    "red-alert",
    "israel",
    "pikud-haoref",
    "civil-defense",
    "rocket-alerts"
  ],
  "author": "Mikhail Kogan <kogan.mikhail@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@logtail/node": "^0.5.6",
    "grammy": "^1.35.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}

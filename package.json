{
  "name": "easyoref-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "EasyOref — Real-time Israeli civil defense alerts → Telegram",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/bot",
    "build": "tsc -b",
    "start": "npm run start --workspace=packages/bot",
    "lint": "npm run lint --workspace=packages/bot",
    "typecheck": "npm run typecheck --workspace=packages/bot",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version-bump": "changeset version",
    "release": "npm run build && npm publish -w packages/bot --access public --provenance",
    "prepare": "husky"
  },
  "author": "Mikhail Kogan <kogan.mikhail@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.0.0",
    "danger": "^13.0.5",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ai": "^6.0.137"
  }
}

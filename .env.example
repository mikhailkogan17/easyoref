# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EasyOref Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Required ──────────────────────────────────────────

# Telegram bot token (from @BotFather)
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram chat ID (negative number for groups)
# Tip: forward a message from your group to @userinfobot to get the ID
CHAT_ID=-1001234567890

# Hebrew area names to monitor (comma-separated)
# See areas.json for the full list, or run: npx @easyoref/cli list-areas
AREAS=תל אביב - דרום העיר ויפו,גוש דן

# ── Optional ──────────────────────────────────────────

# Message language: ru | en | he (default: ru)
LANGUAGE=ru

# Health endpoint port (default: 3100)
HEALTH_PORT=3100

# Oref API poll interval in ms (default: 2000)
# OREF_POLL_INTERVAL_MS=2000

# Better Stack Logtail token (optional, for cloud logging)
# LOGTAIL_TOKEN=your_logtail_token

# ─────────────────────────────────────────────────
# EasyOref — Configuration
# Copy this file to config.yaml and fill in your values.
# ─────────────────────────────────────────────────

# ── Monitoring ────────────────────────────────────
# City IDs to monitor (from cities.json).
# Find IDs: https://raw.githubusercontent.com/eladnava/pikud-haoref-api/master/cities.json
# Example: 722 = תל אביב - דרום העיר ויפו
city_ids:
  - 722
  # - 723  # Another area...

# Which alert types to forward (omit = all three):
#   early     — early warning (e.g. hostiles detected)
#   siren     — red alert / rocket siren
#   resolved  — all-clear
alert_types:
  - early
  - siren
  - resolved

# ── Telegram ──────────────────────────────────────
telegram:
  bot_token: ""        # from @BotFather (or mount Docker secret)
  chat_id: ""          # negative for groups, e.g. "-1001234567890"

# ── Language & GIF ────────────────────────────────
# ru | en | he | ar
language: ru

# funny_cats | none
gif_mode: none

# ── Overrides (optional) ─────────────────────────
# Override the default emoji, title, or description per alert type.
# Each field is independent — override any combination.
# Leave commented out to use built-in i18n strings.
#
# emoji_override:
#   early: "🚀"
#   siren: "🛑"
#   resolved: "✅"
#
# title_override:
#   siren: "Azaka"
#   early: "Early warning"
#   resolved: "All clear"
#
# description_override:
#   siren: ""                          # empty string = no description line
#   early: "Stay alert, follow instructions."
#   resolved: "You may leave the shelter."

# ── Observability (optional) ─────────────────────
# observability:
#   betterstack_token: ""   # Logtail source token

# ── Advanced ─────────────────────────────────────
# poll_interval_ms: 2000
# health_port: 3100
# data_dir: ./data
# oref_api_url: https://www.oref.org.il/WarningMessages/alert/alerts.json

# ── AI Enrichment (optional) ─────────────────────
# Enriches bot messages with data scraped from Telegram news channels via
# GramJS MTProto + LangGraph. Edits the sent message in-place.
# Channels are hardcoded in src/agent/gramjs-monitor.ts
#
# ai:
#   enabled: false
#
#   # OpenRouter API key — get at openrouter.ai/settings/keys
#   openrouter_api_key: "sk-or-v1-..."
#   openrouter_filter_model: google/gemini-2.5-flash-lite  # cheap channel pre-filter
#   openrouter_extract_model: google/gemini-3.1-flash-lite-preview   # expensive per-post extraction
#
#   # Redis (also used by BullMQ queue)
#   redis_url: redis://redis:6379  # use redis://localhost:6379 outside Docker
#
#   # Residential SOCKS5 proxy for GramJS (optional)
#   # socks5_proxy: socks5://user:pass@host:1080
#
#   # Delay before running agent after alert (ms). Default 2 min.
#   enrich_delay_ms: 120000
#
#   # Minimum confidence to edit message (0–1). Default 0.7.
#   confidence_threshold: 0.7
#
#   # MCP tool calling in clarify node (requires GramJS + Redis).
#   # When true, low-confidence results get an extra LLM call with 2 MCP tools:
#   #   - telegram_mtproto_mcp_read_sources (fetch last N posts from channels)
#   #   - pikud_haoref_mcp (official Oref API ground truth)
#   # The LLM decides autonomously whether to call 0, 1, or 2 tools.
#   mcp_tools: false
#
#   # How many posts to fetch per read_sources tool call (1-4). Default 3.
#   clarify_fetch_count: 3
#
#   # Collect channel posts within ±N minutes of alert_ts. Default 2.
#   window_minutes: 2
#
#   # Stop monitoring if no resolved after N minutes. Default 15.
#   timeout_minutes: 15
#
#   # Burner Telegram account credentials (run `npx tsx src/agent/auth.ts` for QR login)
#   mtproto:
#     api_id: 2040       # Telegram Desktop public app_id — not secret
#     api_hash: "b18441a1ff607e10a989891a5462e627"
#     session_string: "" # filled by auth.ts after first login
#   area_labels:
#     "תל אביב": "Дан центр"
#     "חיפה": "Север (Хайфа)"
#     "קריות": "Галилея (Крайот)"
#     "ירושלים": "Иерусалим"

